# Local database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/industrial_ops_brain
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/industrial_ops_brain_test
DATABASE_SCHEMA=

# Backend HTTP/runtime
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_MB=25
DEBUG_ERRORS=false

# Backend logging
LOG_LEVEL=INFO
TERMINAL_LOG_LEVEL=INFO
SQLALCHEMY_ECHO=false
SQLALCHEMY_ECHO_POOL=false
SQLALCHEMY_LOG_LEVEL=WARNING

# Local embeddings and vector search
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_DIR=backend/data/fastembed
EMBEDDING_LOCAL_FILES_ONLY=true

# Only permitted external API
DEEPSEEK_API_KEY=sk_example_not_a_real_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_JSON_SCHEMA=true
LLM_MAX_ATTEMPTS=5
LLM_JSON_ATTEMPTS=2
LLM_OUTPUT_ATTEMPTS=2
LLM_RETRY_BASE_SECONDS=1.0
LLM_RETRY_MAX_SECONDS=20.0
LLM_TIMEOUT_SECONDS=45.0

# Parsing and OCR
ENABLE_OCR=true
OCR_ENGINE=rapidocr
OCR_MIN_TEXT_CHARACTERS=80

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_TERMINAL_BROWSER_LOGS=1
NEXT_PUBLIC_TERMINAL_LOG_LEVEL=info
