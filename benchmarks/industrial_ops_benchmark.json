	"quality_gates": {
		"minimum_score": 1.0,
		"minimum_citation_hit_rate": 1.0,
		"minimum_answer_snippet_hit_rate": 1.0,
		"minimum_retrieval_context_precision": 0.45,
		"minimum_retrieval_context_recall": 0.75,
		"minimum_retrieval_mrr": 0.45,
		"minimum_retrieval_ndcg_at_k": 0.7,
		"minimum_grounded_answer_claim_f1": 1.0,
		"minimum_grounding_citation_coverage": 1.0,
		"minimum_abstention_accuracy": 1.0,
		"minimum_entity_precision": 1.0,
		"minimum_entity_recall": 1.0,
		"minimum_numeric_reasoning_accuracy": 1.0,
		"minimum_compliance_gap_accuracy": 1.0,
		"minimum_contradiction_pair_accuracy": 1.0,
		"minimum_rca_evidence_accuracy": 1.0,
		"minimum_graph_link_completeness": 1.0,
		"minimum_graph_validation_accuracy": 1.0,
		"minimum_parser_contract_coverage": 1.0,
		"minimum_source_document_coverage": 1.0,
		"minimum_source_format_coverage": 1.0,
		"minimum_source_document_count": 17,
		"minimum_source_format_count": 5,
		"minimum_category_count": 12,
		"minimum_check_count": 65,
		"maximum_total_latency_ms": 10000,
		"maximum_parse_latency_ms": 7000,
		"maximum_p95_check_latency_ms": 25
